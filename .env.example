# JiraGuard — Environment variables template
# Copy to .env and fill your values — never commit .env

JIRA_BASE_URL=https://YOUR-SITE.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-atlassian-api-token
USE_REAL_JIRA=false
GROQ_API_KEY=your-groq-api-key
PYTHONUTF8=1

# Note: remove trailing slash from JIRA_BASE_URL
# CORRECT:   https://your-site.atlassian.net
# INCORRECT: https://your-site.atlassian.net/
